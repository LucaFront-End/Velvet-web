{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/pages-sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/services-sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/landings-sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/api/render" }
  ]
}
